# إعداد Nginx كوسيط عكسي + HTTPS أمام التطبيق
# انسخه إلى: /etc/nginx/sites-available/awqaf  ثم فعّله بـ symlink إلى sites-enabled
# احصل على شهادة SSL مجاناً عبر:  sudo certbot --nginx -d app.awqaf-damas.com

server {
    listen 80;
    server_name app.awqaf-damas.com;
    # إعادة توجيه كل HTTP إلى HTTPS (يضيفها certbot تلقائياً عادةً)
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl;
    server_name app.awqaf-damas.com;

    # تملأ هذه الأسطر بواسطة certbot:
    # ssl_certificate     /etc/letsencrypt/live/app.awqaf-damas.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/app.awqaf-damas.com/privkey.pem;

    client_max_body_size 12M;   # للسماح برفع الصور

    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
